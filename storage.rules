rules_version = '2';
// Firebase Storage (item images). Separate from Firestore rules.
// Deploy: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    // Signed-in users can read/write their own item images: items/{uid}/{itemId}/...
    match /items/{userId}/{itemId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Signed-in users can read/write their own storefront configurator assets (e.g. featured PC ad photos)
    match /storefrontAssets/{userId}/{assetId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // AI-generated product cards (high-quality gallery history)
    match /product-cards/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
