# Optional: copy to scripts/.env.browser-scrape

# Browser with --remote-debugging-port (default 9222)
# CDP_URL=http://127.0.0.1:9222

# Seller Hub orders page — use the exact URL from your address bar (ebay.de / ebay.com)
# EBAY_ORDERS_URL=https://www.ebay.de/sh/ord

# Keep orders from this calendar year onward (parsed from German DD.MM.YYYY in the row text)
# FROM_YEAR=2026

# MAX_SCROLL_ROUNDS=40
# MAX_NEXT_CLICKS=25
# PAUSE_MS=900
