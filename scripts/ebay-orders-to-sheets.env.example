# Copy this file to: scripts/.env.ebay-sheets
# (or put the same variables in .env at the project root)

# Required: eBay user OAuth access token (sell.fulfillment or sell.fulfillment.readonly)
# Same kind of token you store in DeInventory Settings for eBay.
EBAY_OAUTH_TOKEN=

# Optional: first day to include (default: 2026)
# EBAY_FROM_YEAR=2026

# Optional: end date YYYY-MM-DD (default: today UTC)
# EBAY_TO_DATE=2026-12-31

# Required: path to Google service account JSON key file (not committed to git)
GOOGLE_SERVICE_ACCOUNT_PATH=./scripts/secrets/google-service-account.json

# Optional: your Gmail — script will grant write access to the new spreadsheet
GOOGLE_SHARE_WITH_EMAIL=you@gmail.com
