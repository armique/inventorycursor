rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write their own document at users/{userId}/...
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Public store catalog (document storeCatalog/public): anyone can read; only signed-in users can write
    match /storeCatalog/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Public storefront configurator settings (document storefrontConfig/public): anyone can read; only signed-in users can write
    match /storefrontConfig/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Store inquiries: anyone can create; only signed-in users can read/update/delete
    match /storeInquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Cached real product photos (by product name) reused across matching items: signed-in only
    match /productPhotoCache/{docId} {
      allow read, write: if request.auth != null;
    }

    /**
     * Short-lived phone→PC photo upload sessions.
     * Owner creates/revokes; anyone signed in (incl. anonymous on phone) can read an active
     * session and append to uploadedUrls only.
     */
    match /photoUploadSessions/{token} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.itemId is string
        && request.resource.data.maxPhotos is number
        && request.resource.data.maxPhotos >= 1
        && request.resource.data.maxPhotos <= 12;

      allow read: if request.auth != null;

      allow update: if request.auth != null && (
        // Owner can revoke / edit metadata
        (resource.data.ownerUid == request.auth.uid)
        ||
        // Phone (anonymous or signed-in) may only append uploadedUrls while active
        (
          resource.data.status == 'active'
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.itemId == resource.data.itemId
          && request.resource.data.token == resource.data.token
          && request.resource.data.uploadedUrls is list
          && request.resource.data.uploadedUrls.size() <= resource.data.maxPhotos
          && request.resource.data.uploadedUrls.size() >= resource.data.uploadedUrls.size()
        )
      );

      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }
  }
}
