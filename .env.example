# Copy this file to .env and fill in your keys (do not commit .env)
# The app tries providers in order; if one fails (e.g. rate limit), it uses the next.

# --- FREE: Groq (https://console.groq.com → API Keys) ---
# VITE_GROQ_API_KEY=

# --- FREE local: Ollama (install Ollama, run "ollama run llama3.2") ---
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=llama3.2

# --- FREE: Gemini (https://aistudio.google.com/apikey) ---
# VITE_GEMINI_API_KEY=
# (Browser + Vite build. Also used for eBay screenshot parse in the client fallback.)
#
# Server-side keys (Vercel Functions — no VITE_ prefix required):
# GEMINI_API_KEY=          # Deal Hunter live search (Google Search grounding)
# GROQ_API_KEY=            # Backup: refines query + marketplace search links if Gemini empty
# TOGETHER_API_KEY=
# MISTRAL_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_SEARCH_API_KEY=   # "Find real photos" in item editor — see API_KEYS_GUIDE.md #8
# GOOGLE_SEARCH_CX=        # Programmable Search Engine ID (image search enabled)
# BING_SEARCH_API_KEY=     # Fallback photo search — Azure "Bing Search v7" resource key
# EBAY_CLIENT_ID=          # Fallback photo search — eBay Browse API (developer.ebay.com/my/keys)
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE_ID=     # optional, defaults to EBAY_DE
# PIXABAY_API_KEY=         # Fallback photo search — free, no billing account needed
# UNSPLASH_ACCESS_KEY=     # Fallback photo search — free, no billing account needed
# PEXELS_API_KEY=          # Fallback photo search — free, no billing account needed

# --- FREE / trial: Together (https://api.together.xyz/settings/api-keys) ---
# VITE_TOGETHER_API_KEY=

# --- FREE tier: Mistral (https://console.mistral.ai) ---
# VITE_MISTRAL_API_KEY=

# --- Product photo enhance + Gemini product card (Flags wand button) ---
# GEMINI_API_KEY=          # AI bg removal, dust cleanup, premium product-card image gen
#                          # Key from https://aistudio.google.com/apikey (NOT Gemini app Pro alone)
# REMOVE_BG_API_KEY=       # Background removal only (remove.bg — paid, ~50 free/month)

# VITE_OPENAI_API_KEY=
# (gpt-4o: can parse eBay order screenshots from image URLs when the browser cannot fetch the image.)
# VITE_ANTHROPIC_API_KEY=

# --- GitHub OAuth (Sign in with GitHub for backup sync) ---
# Get Client ID from GitHub → Settings → Developer settings → OAuth Apps → New.
# Callback URL: https://YOUR_VERCEL_DOMAIN/auth/github/callback (or http://localhost:5173/auth/github/callback for dev).
# On Vercel, also set: GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET (from the same OAuth App).
# VITE_GITHUB_CLIENT_ID=
